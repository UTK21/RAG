# --- LLM (Groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Embeddings (bi-encoder, used for fast wide retrieval) ---
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Re-ranker (cross-encoder, used for precise top-k selection) ---
RERANK_MODEL=BAAI/bge-reranker-base

# --- Chunking (parent-child / small-to-big) ---
# Parent = big context unit sent to the LLM after a match.
PARENT_SIZE=1200
PARENT_OVERLAP=200
# Child = small unit we embed and search. Children live INSIDE a parent.
CHILD_SIZE=240
CHILD_OVERLAP=40

# --- Retrieval (hybrid: dense + sparse, fused with RRF, then re-ranked) ---
# Stage 1: dense (FAISS) AND sparse (BM25) each return this many candidates.
RETRIEVE_K=20
# RRF dampening constant — the standard paper value, almost never needs changing.
RRF_K=60
# Stage 2: cross-encoder picks this many fused candidates to send to the LLM.
TOP_K=4

# --- Generation ---
TEMPERATURE=0.2
# Conversation memory: how many past messages to keep around.
HISTORY_TURNS=5
