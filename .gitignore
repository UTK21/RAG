# ============================================================================
# Secrets — NEVER commit
# ============================================================================
# Environment files with API keys, tokens, DB passwords, etc.
# .env.example is the safe-to-commit template — re-include it below.
.env
.env.*
!.env.example

# Credential / key / token files
*.pem
*.key
*.p12
*.pfx
*.crt
credentials.json
credentials.yaml
credentials.yml
secrets.json
secrets.yaml
secrets.yml
service-account*.json
service_account*.json
client_secret*.json
*-credentials.json
api_keys*
*.token
.netrc

# Cloud SDK local configs that sometimes leak into project dirs
.aws/
.gcp/
.azure/

# ============================================================================
# Claude Code local files — keep on disk, never commit/push
# ============================================================================
.claude/

# ============================================================================
# Python — virtual environments
# ============================================================================
.venv/
venv/
env/
ENV/

# ============================================================================
# Python — bytecode, build artifacts, packaging
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
build/
dist/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# ============================================================================
# Python — test, type, lint caches
# ============================================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml
.hypothesis/

# ============================================================================
# Jupyter
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================================
# ML / RAG specific
# ============================================================================
# HuggingFace, sentence-transformers, torch caches if ever copied into repo
.cache/
.huggingface/
.transformers_cache/

# Logs
*.log
logs/

# ============================================================================
# Editor / IDE
# ============================================================================
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
*.bak

# ============================================================================
# OS noise
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
